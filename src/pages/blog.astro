---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="Blog | Alimentos Pronalfrut">
  <Navbar logoText="Pronalfrut" />
  
  <main class="max-w-4xl mx-auto px-4 py-24 text-center">
    <h1 class="text-4xl font-bold text-gray-800 mb-4">Nuestro blog</h1>
    <p class="text-xl text-green-700 font-medium mb-6">
      ¿Próximamente más contenido de las mejores pulpas de frutas? ¡Claro que sí!
    </p>
    <a href="/" class="inline-block bg-green-600 text-white px-6 py-2 rounded-full hover:bg-green-700 transition-all">
      Volver al inicio
    </a>
  </main>

  <Footer />
</MainLayout>

