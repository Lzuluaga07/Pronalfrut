---
import traducciones from '../data/idiomas.json';
import TituloSeccion from './TituloSeccion.astro';

const esIngles = Astro.url.pathname.startsWith('/en');
const idioma = esIngles ? 'en' : 'es';

const t = traducciones[idioma].contacto;
---

<section id="contacto" class="py-16 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <TituloSeccion texto={t.titulo} />
    </h2>

<!-- Contenedor horizontal -->
<div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-16">
  
  <!-- Dirección -->
  <div class="flex flex-col items-center gap-2">
    <div class="w-16 h-16 bg-purple-700 rounded-full flex items-center justify-center text-4xl text-white">📍</div>
    <p class="text-sm font-semibold text-gray-700">Cra. 64A #4b-41, Bogotá D.C.</p>
  </div>

  <!-- Ejemplo del Teléfono -->
<a href="tel:+576014202730" class="flex flex-col items-center gap-2 cursor-pointer z-10">
  <!-- Línea 27: Aquí insertamos el icono dentro del div morado -->
  <div class="w-16 h-16 bg-purple-700 rounded-full flex items-center justify-center text-white">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
   
<a href="mailto:sales@pronalfrut.com" class="flex flex-col items-center gap-2 cursor-pointer z-10">
  <!-- Línea 32: Añadimos el icono de sobre -->
  <div class="w-16 h-16 bg-purple-700 rounded-full flex items-center justify-center text-white">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
  </div>
  <!-- Línea 34: Tu texto sigue igual -->
  <p class="text-sm font-semibold text-gray-700">sales@pronalfrut.com</p>
</a>

  <!-- Email (ENLACE DE CORREO) -->
  <a href="mailto:sales@pronalfrut.com" class="flex flex-col items-center gap-2 hover:opacity-80 transition-opacity">
    <div class="w-16 h-16 bg-purple-700 rounded-full flex items-center justify-center text-4xl text-white">✉️</div>
    <p class="text-sm font-semibold text-gray-700">sales@pronalfrut.com</p>
  </a>

</div>


  <!-- Mapa a ancho total -->
    <div class="w-full h-[400px] mt-16 shadow-xl border-t border-gray-200">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15907.321632758774!2d-74.13116528335796!3d4.624327925915589!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f99545f1fa85f%3A0x90eac8ae72c6e03f!2zQ3JhLiA2NGEgIyA0Qi00MSwgUHVlbnRlIEFyYW5kYSwgQm9nb3TDoSwgRC5DLiwgQm9nb3TDoSwgQm9nb3TDoSwgRC5DLg!5e0!3m2!1ses!2sco!4v1782916111828!5m2!1ses!2sco" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="strict-origin-when-cross-origin">
      </iframe>
    </div>

   
   



            







