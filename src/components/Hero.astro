---
import traducciones from '../data/idiomas.json';
const esIngles = Astro.url.pathname.startsWith('/en');
const idioma = esIngles ? 'en' : 'es';
const t = traducciones[idioma].hero as any;
---

<section class="relative w-full h-[600px] flex items-center justify-center overflow-hidden">
    <!-- Imagen de fondo -->
    <img 
        src="/images/portada.webp" 
        alt="Pulpa de mora Pronalfrut" 
        class="absolute inset-0 w-full h-full object-cover Object-center"
    />
    
    <!-- Capa oscura para asegurar legibilidad -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Contenido centrado -->
    <div class="relative z-10 text-center text-white px-4">
        
        <!-- Línea 1: Estilo Serif Cursivo -->
        <p class="font-serif italic text-2xl md:text-3xl mb-4 drop-shadow-md">
            {t.subtitle}
        </p>

        <!-- Línea 2: Estilo Sans-Serif, Mayúsculas y Espaciado -->
        <h1 class="font-sans font-bold text-4xl md:text-6xl tracking-[0.2em] uppercase drop-shadow-xl mb-4">
         {t.title}
        </h1>
      

        <!-- Línea 3: Subtítulo (Bienvenido) -->
        <p class="font-sans text-xl md:text-2xl mt-4 mb-10 drop-shadow-md">
            {t.bienvenida}  
        </p>

    

        <!-- Línea 4: Cursiva inferior -->
        <p class="font-serif italic text-lg mt-16 drop-shadow-md">
            
        </p>
    </div>
</section>

















