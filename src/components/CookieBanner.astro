<!-- Ventana centralizada (Modal) -->
<div id="cookie-banner" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-[9999] hidden">
  <div class="bg-white p-6 rounded-lg shadow-xl max-w-sm w-full text-center">
    <h2 class="text-xl font-bold mb-4 text-gray-800">Política de Cookies</h2>
    <p class="text-gray-600 mb-6 text-sm">
      Utilizamos cookies para mejorar tu experiencia en Alimentos Pronalfrut. ¿Estás de acuerdo?
    </p>
    <button id="accept-cookies" class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded transition-colors">
      Aceptar y continuar
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const button = document.getElementById('accept-cookies');

 // Verificamos si el usuario ya aceptó antes
  if (sessionStorage.getItem('cookies_accepted') === 'true') {
    banner?.classList.add('hidden');
  } else {
    // Si no ha aceptado, lo mostramos
    banner?.classList.remove('hidden');
  }

  // Al hacer clic, guardamos la aceptación en sessionStorage
  button?.addEventListener('click', () => {
    sessionStorage.setItem('cookies_accepted', 'true');
    banner?.classList.add('hidden');
  }); 
</script>


