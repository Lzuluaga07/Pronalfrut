<!-- Agregamos 'pt-12' para crear espacio arriba del video -->
<section class="w-full pt-12"> 
  <div class="relative w-full">
    
 <video 
  autoplay 
  loop 
  muted 
  playsinline 
  preload="metadata" 
  class="w-full h-[50vh] md:h-[70vh] object-cover object-top"
>
  <source src="/videos/cosecha.mp4" type="video/mp4" />
  Tu navegador no soporta la reproducción de videos.
</video>   

    <!-- ... resto del código ... -->
    <!-- Logo centrado -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <img
        src="/test-logo.png"
        alt="Logo Pronalfrut"
        class="w-48 md:w-64 opacity-80"
      />
    </div>
  </div>
</section>




