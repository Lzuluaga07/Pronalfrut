---
// src/components/TituloSeccion.astro
interface Props {
  texto: string;
}

const { texto } = Astro.props;


// Cambia la línea 10 por esta versión segura:
const tituloFormateado = texto ? texto.charAt(0).toUpperCase() + texto.slice(1) : "";
---

<h2 class="text-4xl font-bold text-green-800 text-center my-10 capitalize">
  {tituloFormateado}
</h2>
