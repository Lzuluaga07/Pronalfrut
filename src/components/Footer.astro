---
import traducciones from '../data/idiomas.json';

const currentYear = new Date().getFullYear();
const esIngles = Astro.url.pathname.startsWith('/en');
const idioma = esIngles ? 'en' : 'es';

const t = traducciones[idioma].footer;
---

<footer id="contacto" class="bg-[#4c1d95] text-white py-12 mt-10">
    <!-- Contenedor con margen forzado a la izquierda -->
    <div class="container mx-auto px-6 md:pl-48 grid grid-cols-1 md:grid-cols-3 gap-10 max-w-screen-xl">
        
        <!-- Bloque 1 -->
        <div class="space-y-4">
            <h3 class="text-2xl font-bold">Alimentos Pronalfrut</h3> 
            <p class="text-sm text-purple-200 font-semibold">NIT: 900436915</p>
            <p class="text-purple-100 text-sm">{t.descripcion}</p>
        </div>

        <!-- Bloque 2 -->
        <div class="space-y-4">
            <h3 class="text-xl font-bold border-b-2 border-green-500 w-fit pb-1">{t.navTitulo}</h3>
            <ul class="space-y-2 text-purple-100 text-sm">
                <li><a href="/" class="hover:text-green-400">Inicio</a></li>
                <li><a href="#nosotros" class="hover:text-green-400">Nosotros</a></li>
                <li><a href="#productos" class="hover:text-green-400">Productos</a></li>
                <li><a href="#testimonios" class="hover:text-green-400">Nuestros clientes</a></li>
            </ul>
        </div>

        <!-- Bloque 3 -->
        <div class="space-y-4"> 
            <h3 class="text-xl font-bold border-b-2 border-green-500 w-fit pb-1">{t.contactoTitulo}</h3>
            <div class="text-purple-100 text-sm space-y-2">
                <p>Cra. 64A # 4B-41, Bogotá</p>
                <p>601 420 2730</p>
                <p>sales@pronalfrut.com</p>
            </div>
        </div> 
 
    </div> 
    
 <div class="w-full bg-white p-8 mt-10 text-center">
      <a 
        href="mailto:sales@pronalfrut.com" 
        class="inline-block bg-purple-700 text-white px-10 py-3 rounded-full font-bold hover:bg-purple-800 transition-colors shadow-lg"
      >
        Enviar correo a ventas
      </a>
    </div>




    <!-- Redes sociales: Mantienen su contenedor para estar centradas -->
    <div class="container mx-auto px-6 mt-6">
        <div class="flex justify-center gap-6">
            <a href="https://www.facebook.com/pronalfrut" target="_blank"><img src="/images/facebook.svg" alt="Facebook" class="w-10 h-10 filter invert"></a>
            <a href="https://www.instagram.com/pronalfrut" target="_blank"><img src="/images/instagram.svg" alt="Instagram" class="w-10 h-10 filter invert"></a>
        </div> 

   <!-- Botón flotante de WhatsApp profesional -->
<!-- Botón flotante de WhatsApp Oficial con teléfono -->
<a 
  href="https://wa.me/573123456789" 
  target="_blank"
  class="fixed bottom-8 right-8 z-[9999] bg-green-500 p-6 rounded-full shadow-2xl hover:scale-110 transition-transform duration-300 ease-in-out flex items-center justify-center"
  aria-label="Chatea con nosotros por WhatsApp"
>
