---
import TituloSeccion from './TituloSeccion.astro';
interface Testimonial {
    quote: string;
    author: string;
    rating: number;
    image: string;
}

interface Props {
    title?: string;
    message?: string; // Agregamos una propiedad para el mensaje
    testimonials?: Testimonial[];
}

const {
    title = "Nuestros clientes",
    message = "Próximamente conocerás las opiniones de las empresas que confían en nosotros.",
    testimonials = []
} = Astro.props;
---

<section class="relative overflow-hidden bg-[#f5f5f5] px-6 py-16" id="testimonios">
    <div class="container mx-auto max-w-7xl">
        <TituloSeccion texto={title} />
        
        <div class="text-center text-gray-600 italic py-12 bg-white rounded-2xl shadow-sm">
            <p class="text-lg px-6">
                {message} <!-- Aquí usamos la propiedad dinámica -->
            </p>
        </div>
    </div>
</section>


