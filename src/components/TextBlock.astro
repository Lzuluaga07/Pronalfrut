---
export interface Props {
  title: string;
  paragraph: string;
  align?: "left" | "center" | "right";
}

const {
  title,
  paragraph,
  align = "center",
} = Astro.props;

const alignment = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};
---

<section class="py-16 px-4 bg-white">
    <div class="mx-auto max-w-4xl text-center">
        <!-- Título centrado con text-center -->
        <h2 class="text-4xl font-bold text-green-800 my-10 text-center">
            {title}
        </h2>


    <!-- Eliminamos el bloque que dibujaba la línea naranja (bg-orange-500) -->

    <p class="text-lg md:text-xl leading-relaxed text-gray-700 text-justify whitespace-pre-line">
      {paragraph}
    </p>
    
  </div>
</section>

